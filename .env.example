# OpenMEP Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit the actual .env file — it is in .gitignore.

# ----------------------------------------------------------
# PostgreSQL (required when running docker-compose with db)
# ----------------------------------------------------------
POSTGRES_DB=openmep
POSTGRES_USER=openmep
# Change this before deploying — do not use the default in production
POSTGRES_PASSWORD=change_me_in_production

# Full connection URL used by the application
DATABASE_URL=postgresql://openmep:change_me_in_production@db:5432/openmep

# ----------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins.
# Development: localhost only (Streamlit + React dev server)
# Production: replace with your actual public domain(s)
# Example: https://app.mycompany.com,https://www.mycompany.com
# ----------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000,http://localhost:5173

# ----------------------------------------------------------
# FastAPI settings
# ----------------------------------------------------------
# Number of Uvicorn worker processes (production: match CPU core count)
API_WORKERS=2
API_PORT=8000

# Show exception details in 500 responses — development only
DEBUG=false

# ----------------------------------------------------------
# Streamlit settings
# ----------------------------------------------------------
# URL for Streamlit to reach the FastAPI calculation engine.
# Inside docker-compose network: http://api:8000
# Local dev / VPS without Docker: http://localhost:8000
API_BASE=http://localhost:8000

# URL for Streamlit to reach the Node.js Project Management API.
# Inside docker-compose network: http://node-api:8080
# Local dev / VPS without Docker: http://localhost:8080
NODE_API_BASE=http://localhost:8080

STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ----------------------------------------------------------
# Node.js Project Management API settings
# ----------------------------------------------------------
# Port for the Express server (default: 8080)
PORT=8080

# Directory where project JSON files are stored on disk.
# Docker Compose: /data/projects (bind-mounted as "projectdata" volume)
# VPS without Docker: /home/openmep/openmep/data/projects
# Local development: ./data/projects (auto-created on first run)
PROJECTS_DIR=./data/projects

# Log verbosity for the Node.js service: silent | info | warn | error
LOG_LEVEL=info

# Node.js environment
NODE_ENV=production

# ----------------------------------------------------------
# API Key Authentication (optional)
# ----------------------------------------------------------
# When set, all API requests (except /health, /docs, /redoc) must include:
#   X-API-Key: <your-key-here>
# When NOT set (the default), the API is open — suitable for local development
# and deployments behind a VPN or reverse proxy that handles auth.
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# API_KEY=
